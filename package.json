{
  "name": "opentyme-addon-ai-analysis",
  "version": "1.0.0",
  "description": "AI-powered expense analysis addon for OpenTYME with receipt extraction and depreciation calculation",
  "main": "backend/src/index.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "build": "tsc",
    "clean": "rm -rf dist coverage",
    "validate": "npm run type-check && npm run lint && npm run test"
  },
  "keywords": [
    "opentyme",
    "addon",
    "plugin",
    "ai",
    "expense-analysis",
    "receipt-extraction",
    "depreciation",
    "afa",
    "tax"
  ],
  "author": "OpenTYME Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentyme/opentyme-addon-ai-analysis.git"
  },
  "bugs": {
    "url": "https://github.com/opentyme/opentyme-addon-ai-analysis/issues"
  },
  "homepage": "https://github.com/opentyme/opentyme-addon-ai-analysis#readme",
  "peerDependencies": {
    "express": "^4.18.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
